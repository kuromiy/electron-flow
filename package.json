{
  "name": "electron-flow",
  "version": "0.1.1",
  "description": "Type-safe IPC code generator for Electron applications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "electron-flow": "./bin/electron-flow"
  },
  "scripts": {
    "build": "npx tsc -p tsconfig.build.json",
    "dev": "npx tsc -w",
    "test": "npx jest",
    "test:watch": "npx jest --watch",
    "test:coverage": "npx jest --coverage",
    "test:ci": "npx jest --ci --coverage --watchAll=false",
    "tdd": "npx jest --watch --verbose",
    "lint": "npx eslint src --ext .ts",
    "lint:fix": "npx eslint src --ext .ts --fix",
    "format": "npx prettier --write \"src/**/*.ts\"",
    "format:check": "npx prettier --check \"src/**/*.ts\"",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run lint && npm run build"
  },
  "files": [
    "dist",
    "bin",
    "templates"
  ],
  "keywords": [
    "electron",
    "ipc",
    "typescript",
    "code-generator",
    "type-safe",
    "result-type",
    "error-handling"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/electron-flow.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/electron-flow/issues"
  },
  "homepage": "https://github.com/yourusername/electron-flow#readme",
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^3.5.3",
    "commander": "^11.1.0",
    "lodash": "^4.17.21",
    "ora": "^8.0.1",
    "ts-morph": "^21.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/lodash": "^4.17.17",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "electron": ">=13.0.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": false
    },
    "zod": {
      "optional": false
    }
  },
  "engines": {
    "node": ">=16.0.0"
  }
}